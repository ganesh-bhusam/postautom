# Gemini AI & Multi-LLM Configuration
# You can specify multiple free API keys comma-separated: key1,key2,key3
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
ENABLE_WEB_UI_LLMS=true

# Target X / Twitter Feed URL
X_TARGET_URL=https://x.com/home

# Browser & Profile Settings
PROFILE_DIR=./user_data_dir
HEADLESS=false

# Automation & Rate Limits
MAX_REPLIES_PER_RUN=10
AUTO_LIKE_ENABLED=true
AUTO_REPLY_ENABLED=true
DRY_RUN=false

# Anti-Bot Jitter Settings (in milliseconds)
TYPING_DELAY_MIN=30
TYPING_DELAY_MAX=100
READING_PAUSE_MIN=3000
READING_PAUSE_MAX=7000
ACTION_COOLDOWN_MIN=15000
ACTION_COOLDOWN_MAX=45000

# Proxy Configuration (Optional)
# PROXY_SERVER=http://residential-proxy-provider.com:8000
# PROXY_USERNAME=your_proxy_user
# PROXY_PASSWORD=your_proxy_pass
